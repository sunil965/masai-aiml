\f2\fs29\fsmilli14667 # Load a dataset
\f1\fs24 \

\f2\fs29\fsmilli14667 df = pd.read_csv("salary_data.csv")
\f1\fs24 \

\f2\fs29\fsmilli14667 # Generate an instant statistical summary
\f1\fs24 \

\f2\fs29\fsmilli14667 summary = df.describe()
